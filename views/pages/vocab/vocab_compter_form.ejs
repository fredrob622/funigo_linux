<%- include('../../partials/header') %>

<div class="content content-black">
    
    <h2>Compter les personnes, les objets, etc..</h2>
    
    <form action="/vocab_compter" method="GET" class="search-form" style="justify-content: center; align-items: flex-end; gap: 15px;">
        
        <div style="text-align: center;">
            <label for="type-select" style="display: inline; margin-bottom: 10px; margin-right: 20px;">Vous voulez compter quoi ? :</label>
            <select id="type-select" name="selection" style="padding: 5px; font-size: 1em; border-radius: 8px; min-width: 300px;margin-right: 20px;">
                <option value="" disabled <%= !searchTerm ? 'selected' : '' %>>-- Sélectionnez --</option>
                <% listeCompteur.forEach(type => { %>
                    <option value="<%= type.compteur_type %>" <%= (type.compteur_type === searchTerm) ? 'selected' : '' %>>
                        <%= type.compteur_type %>
                    </option>
                <% }); %>
            </select>
            <button type="submit">Afficher</button>
        </div>
        
        
    </form>

	
    <% if (results.length > 0) { %>
        <!-- NOUVEAU : On ajoute le conteneur autour du tableau -->
        <div class="results-table-container">
            <h2>Compter:   <%= searchTerm %> (<%= results[0].compteur_compteur %>)</h2>
            
            <!-- NOUVEAU : On ajoute la classe "results-table" au tableau -->
            <table class="results-table">
                <thead>
                    <tr>
                        <th>chiffre</th>
                        <th>Kanji</th>
                        <th>hiragana</th>
                    </tr>
                </thead>
                <tbody>
                    <% results.forEach(result => { %>
                        <tr>
                            <td><%= result.compteur_numero %></td>
                            <td><span class="jp-char"><%= result.compteur_kanji %></span></td>
                            <td><span class="jp-char"><%= result.compteur_hiragana %></span></td>
                            
                        </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    <% } else if (searchTerm) { %>
        <p>Aucun résultat trouvé pour "<%= searchTerm %>".</p>
    <% } %>
</div>

<%- include('../../partials/footer') %>